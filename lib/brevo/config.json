{
  "organizationWelcome": {
    "subject": "Welcome to {{organizationName}}",
    "htmlContent": "<!doctype html><html><body style=\"margin:0;padding:0;background:#f6f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><div style=\"max-width:640px;margin:0 auto;padding:32px 16px;\"><div style=\"background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 8px 24px rgba(15,23,42,0.08);\"><div style=\"background:linear-gradient(135deg,#2563eb,#7c3aed);padding:28px 32px;color:#ffffff;\"><h1 style=\"margin:0;font-size:24px;line-height:1.3;\">Welcome to {{organizationName}}</h1><p style=\"margin:12px 0 0;font-size:15px;line-height:1.7;opacity:0.95;\">Your organization has been created successfully and your admin account is ready.</p></div><div style=\"padding:32px;\"><p style=\"margin:0 0 16px;font-size:15px;line-height:1.7;\">Hi {{adminName}},</p><p style=\"margin:0 0 16px;font-size:15px;line-height:1.7;\">We're happy to have you on board. You can log in to the portal using the credentials below.</p><div style=\"background:#f8fafc;border:1px solid #e5e7eb;border-radius:12px;padding:20px;margin:24px 0;\"><p style=\"margin:0 0 8px;font-size:14px;line-height:1.6;\"><strong>Login email:</strong> {{adminEmail}}</p><p style=\"margin:0 0 8px;font-size:14px;line-height:1.6;\"><strong>Temporary password:</strong> {{adminPassword}}</p><p style=\"margin:0;font-size:14px;line-height:1.6;\"><strong>Login page:</strong> <a href=\"{{loginUrl}}\" style=\"color:#2563eb;text-decoration:none;\">{{loginUrl}}</a></p></div><p style=\"margin:0 0 16px;font-size:15px;line-height:1.7;\">Please sign in and update your password after the first login.</p><p style=\"margin:0 0 16px;font-size:15px;line-height:1.7;\">If you need any help, reach us at <a href=\"mailto:{{supportEmail}}\" style=\"color:#2563eb;text-decoration:none;\">{{supportEmail}}</a>.</p><p style=\"margin:0;font-size:15px;line-height:1.7;\">Best regards,<br/>{{senderName}}</p></div></div></div></body></html>"
  },
  "resetPassword": {
    "subject": "Reset your password",
    "htmlContent": "<!doctype html><html><body style=\"margin:0;padding:0;background:#f6f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><div style=\"max-width:640px;margin:0 auto;padding:32px 16px;\"><div style=\"background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 8px 24px rgba(15,23,42,0.08);\"><div style=\"background:linear-gradient(135deg,#ef4444,#f97316);padding:28px 32px;color:#ffffff;\"><h1 style=\"margin:0;font-size:24px;line-height:1.3;\">Reset your password</h1><p style=\"margin:12px 0 0;font-size:15px;line-height:1.7;opacity:0.95;\">We received a request to reset your account password.</p></div><div style=\"padding:32px;\"><p style=\"margin:0 0 16px;font-size:15px;line-height:1.7;\">Hi {{name}},</p><p style=\"margin:0 0 16px;font-size:15px;line-height:1.7;\">Click the button below to create a new password. This link will expire after a short time for your security.</p><div style=\"text-align:center;margin:28px 0;\"><a href=\"{{resetUrl}}\" style=\"display:inline-block;background:#2563eb;color:#ffffff;text-decoration:none;padding:14px 22px;border-radius:10px;font-size:15px;font-weight:600;\">Reset Password</a></div><p style=\"margin:0 0 16px;font-size:14px;line-height:1.7;color:#4b5563;\">If the button does not work, copy and paste this link into your browser:</p><p style=\"margin:0 0 16px;font-size:14px;line-height:1.7;word-break:break-all;\"><a href=\"{{resetUrl}}\" style=\"color:#2563eb;text-decoration:none;\">{{resetUrl}}</a></p><p style=\"margin:0 0 16px;font-size:15px;line-height:1.7;\">If you did not request this, you can safely ignore this email.</p><p style=\"margin:0;font-size:15px;line-height:1.7;\">Best regards,<br/>{{senderName}}</p></div></div></div></body></html>"
  }
}
